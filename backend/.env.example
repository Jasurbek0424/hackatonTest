# Копируйте в .env и подставьте свои значения
# cp .env.example .env

# Порт приложения (по умолчанию 8080)
SERVER_PORT=8080

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/finpilot
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# API-ключ Anthropic для AI (категоризация, советы). Можно оставить пустым.
ANTHROPIC_API_KEY=

# Разрешённые CORS origins через запятую (для фронтенда)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Включить Swagger UI (true / false)
SWAGGER_UI_ENABLED=true
